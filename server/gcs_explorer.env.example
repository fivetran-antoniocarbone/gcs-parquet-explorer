# GCS Parquet Explorer — Environment Variables
# Copy to /usr/sap/gcs_explorer.env and fill in real values.

# Login password
GCS_EXPLORER_PASSWORD=changeme

# Polaris OAuth credentials — Google Cloud
POLARIS_GCS_CLIENT_ID=your_gcs_client_id
POLARIS_GCS_CLIENT_SECRET=your_gcs_client_secret

# Polaris OAuth credentials — Azure
POLARIS_AZURE_CLIENT_ID=your_azure_client_id
POLARIS_AZURE_CLIENT_SECRET=your_azure_client_secret

# Polaris OAuth credentials — AWS
POLARIS_AWS_CLIENT_ID=your_aws_client_id
POLARIS_AWS_CLIENT_SECRET=your_aws_client_secret
